generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum Platform {
  NAVER
  OWN
}

enum ProductStatus {
  draft
  active
  inactive
}

enum CodeStatus {
  available
  reserved
  sent
  disabled
}

enum OrderItemFulfillmentStatus {
  pending
  awaiting_code
  manual_review
  processing
  dispatch_done_email_pending
  completed
  error_retryable
  error_final
  locked
}

enum CodeAssignmentStatus {
  reserved
  sent
  released
}

enum FulfillmentJobStatus {
  queued
  processing
  succeeded
  failed
}

enum EmailLogStatus {
  queued
  sent
  failed
}

// ───────────────────────── Models ─────────────────────────

model Product {
  id                   String        @id @default(uuid()) @db.Uuid
  name                 String        @db.VarChar(255)
  description          String?
  price                Int
  internalProductCode  String        @unique @map("internal_product_code") @db.VarChar(100)
  naverProductId       String?       @unique @map("naver_product_id") @db.VarChar(100)
  sellerManagementCode String        @unique @map("seller_management_code") @db.VarChar(100)
  emailOptionName      String        @map("email_option_name") @db.VarChar(100)
  mailTemplateId       String?       @map("mail_template_id") @db.Uuid
  status               ProductStatus @default(draft)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  codes               Code[]
  orderItems          OrderItem[]
  inventoryAlertState InventoryAlertState?
  mailTemplate        MailTemplate?        @relation(fields: [mailTemplateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("products")
}

model Code {
  id         String     @id @default(uuid()) @db.Uuid
  productId  String     @map("product_id") @db.Uuid
  codeValue  String     @map("code_value")
  sequenceNo Int        @map("sequence_no")
  status     CodeStatus @default(available)
  reservedAt DateTime?  @map("reserved_at") @db.Timestamptz(6)
  sentAt     DateTime?  @map("sent_at") @db.Timestamptz(6)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  product     Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  assignments CodeAssignment[]

  @@unique([productId, sequenceNo])
  @@index([productId, status, sequenceNo])
  @@map("codes")
}

model Order {
  id           String    @id @default(uuid()) @db.Uuid
  platform     Platform  @default(NAVER)
  naverOrderId String?   @unique @map("naver_order_id") @db.VarChar(100)
  ownOrderId   String?   @unique @map("own_order_id") @db.VarChar(100)
  orderStatus  String    @map("order_status") @db.VarChar(100)
  ordererName  String?   @map("orderer_name") @db.VarChar(255)
  paidAt       DateTime? @map("paid_at") @db.Timestamptz(6)
  totalAmount  Int       @default(0) @map("total_amount")
  rawPayload   Json?     @map("raw_payload")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderItems OrderItem[]

  @@index([paidAt])
  @@index([platform])
  @@map("orders")
}

model OrderItem {
  id                  String                     @id @default(uuid()) @db.Uuid
  orderId             String                     @map("order_id") @db.Uuid
  productId           String?                    @map("product_id") @db.Uuid
  productOrderId      String                     @unique @map("product_order_id") @db.VarChar(100)
  productName         String                     @map("product_name") @db.VarChar(255)
  quantity            Int                        @default(1)
  buyerEmail          String?                    @map("buyer_email") @db.VarChar(320)
  unitPrice           Int                        @default(0) @map("unit_price")
  fulfillmentStatus   OrderItemFulfillmentStatus @default(pending) @map("fulfillment_status")
  failureReasonCode   String?                    @map("failure_reason_code") @db.VarChar(100)
  failureReasonDetail String?                    @map("failure_reason_detail")
  paidAt              DateTime?                  @map("paid_at") @db.Timestamptz(6)
  processedAt         DateTime?                  @map("processed_at") @db.Timestamptz(6)
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product         Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  codeAssignment  CodeAssignment?
  fulfillmentJobs FulfillmentJob[]
  emailLogs       EmailLog[]

  @@index([fulfillmentStatus, createdAt])
  @@index([productId, fulfillmentStatus])
  @@index([buyerEmail])
  @@map("order_items")
}

model CodeAssignment {
  id          String               @id @default(uuid()) @db.Uuid
  orderItemId String               @unique @map("order_item_id") @db.Uuid
  codeId      String               @map("code_id") @db.Uuid
  status      CodeAssignmentStatus @default(reserved)
  assignedAt  DateTime             @default(now()) @map("assigned_at") @db.Timestamptz(6)
  sentAt      DateTime?            @map("sent_at") @db.Timestamptz(6)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  code      Code      @relation(fields: [codeId], references: [id], onDelete: Restrict)

  @@index([codeId, status])
  @@map("code_assignments")
}

model FulfillmentJob {
  id           String               @id @default(uuid()) @db.Uuid
  orderItemId  String               @map("order_item_id") @db.Uuid
  jobType      String               @map("job_type") @db.VarChar(100)
  status       FulfillmentJobStatus @default(queued)
  retryCount   Int                  @default(0) @map("retry_count")
  errorMessage String?              @map("error_message")
  context      Json?
  processedAt  DateTime?            @map("processed_at") @db.Timestamptz(6)
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, jobType, createdAt])
  @@index([status, createdAt])
  @@map("fulfillment_jobs")
}

model EmailLog {
  id                String         @id @default(uuid()) @db.Uuid
  orderItemId       String         @map("order_item_id") @db.Uuid
  recipientEmail    String         @map("recipient_email") @db.VarChar(320)
  provider          String         @db.VarChar(50)
  providerMessageId String?        @map("provider_message_id") @db.VarChar(255)
  templateName      String         @map("template_name") @db.VarChar(100)
  status            EmailLogStatus @default(queued)
  errorMessage      String?        @map("error_message")
  sentAt            DateTime?      @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, createdAt])
  @@index([status, createdAt])
  @@map("email_logs")
}

model MailTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  subject   String   @db.VarChar(255)
  bodyHtml  String   @map("body_html")
  bodyText  String   @map("body_text")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  products Product[]

  @@index([isActive])
  @@map("mail_templates")
}

model InventoryAlertState {
  id                      String   @id @default(uuid()) @db.Uuid
  productId               String   @unique @map("product_id") @db.Uuid
  lowStockAlertSent       Boolean  @default(false) @map("low_stock_alert_sent")
  outOfStockAlertSent     Boolean  @default(false) @map("out_of_stock_alert_sent")
  lastKnownAvailableCount Int      @default(0) @map("last_known_available_count")
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_alert_states")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String
  isSecret  Boolean  @default(false) @map("is_secret")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model DiscordAlertLog {
  id        String   @id @default(uuid()) @db.Uuid
  alertType String   @map("alert_type") @db.VarChar(100)
  dedupeKey String   @map("dedupe_key") @db.VarChar(150)
  payload   Json
  sentAt    DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  @@unique([dedupeKey])
  @@index([alertType, sentAt])
  @@map("discord_alert_logs")
}
