generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Enums ─────────────────────────

// 상품 상태
enum ProductStatus {
  draft    // 임시저장 (비공개)
  active   // 판매 중
  inactive // 판매 중지
}

// 코드 상태
enum CodeStatus {
  available // 사용 가능 (미발송)
  reserved  // 주문에 선점됨 (발송 전)
  sent      // 고객에게 발송 완료
  disabled  // 수동 비활성화
}

// 주문 처리 상태
enum FulfillmentStatus {
  pending       // 주문 수신, 처리 전
  completed     // 코드 발송까지 완료
  manual_review // 수동 처리 필요 (이메일 파싱 실패, 재고 없음 등)
  failed        // 처리 실패
}

// 이메일 발송 상태
enum EmailLogStatus {
  queued // 발송 대기
  sent   // 발송 완료
  failed // 발송 실패
}

// ───────────────────────── Models ─────────────────────────

// 관리자 계정 (시드로 1개 고정, 가입 불가)
model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(320) // 로그인 이메일
  password  String                            // bcrypt 해시
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admins")
}

// 스팀 상품 (네이버 스마트스토어 상품과 1:1 매핑)
model SteamProduct {
  id              String        @id @default(uuid()) @db.Uuid
  name            String        @db.VarChar(255)  // 상품명 (네이버에서 가져옴)
  naverProductId  String        @unique @map("naver_product_id") @db.VarChar(100)  // 네이버 상품 ID (주문 매칭 키)
  description     String?       // 이메일 본문 - 상품 설명
  caution         String?       // 이메일 본문 - 이용 주의사항
  event           String?       // 이메일 본문 - 이벤트 (없으면 이메일에서 생략)
  status          ProductStatus @default(draft)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  codes      SteamCode[]
  orderItems SteamOrderItem[]

  @@map("steam_products")
}

// 스팀 코드 재고 (상품당 N개, 등록 순서대로 소진)
model SteamCode {
  id        String     @id @default(uuid()) @db.Uuid
  productId String     @map("product_id") @db.Uuid
  codeValue String     @map("code_value")           // 실제 스팀 코드값 (예: XXXXX-XXXXX-XXXXX)
  status    CodeStatus @default(available)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6) // FIFO 소진 기준

  product    SteamProduct     @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItems SteamOrderItem[]

  @@index([productId, status, createdAt]) // 사용 가능한 코드를 등록 순서대로 조회할 때 사용
  @@map("steam_codes")
}

// 주문 아이템 (네이버 상품주문 1건 = 1행, 풀필먼트 단위)
model SteamOrderItem {
  id                String            @id @default(uuid()) @db.Uuid
  productOrderId    String            @unique @map("product_order_id") @db.VarChar(100) // 네이버 상품주문번호 (중복 처리 방지 키)
  naverOrderId      String            @map("naver_order_id") @db.VarChar(100)           // 네이버 주문번호 (묶음 주문 조회용)
  productId         String?           @map("product_id") @db.Uuid                       // 매칭된 상품 (매칭 실패 시 null)
  codeId            String?           @map("code_id") @db.Uuid                          // 발송한 코드 (발송 전 null)
  productName       String            @map("product_name") @db.VarChar(255)             // 주문 당시 상품명 (상품 삭제돼도 보존)
  buyerEmail        String?           @map("buyer_email") @db.VarChar(320)              // 구매자 이메일 (파싱 실패 시 null → manual_review)
  unitPrice         Int               @map("unit_price")                                // 결제금액 (네이버 API에서 가져옴)
  fulfillmentStatus FulfillmentStatus @default(pending) @map("fulfillment_status")
  errorMessage      String?           @map("error_message")                             // 실패 사유
  paidAt            DateTime?         @map("paid_at") @db.Timestamptz(6)               // 결제일시
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  product   SteamProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  code      SteamCode?    @relation(fields: [codeId], references: [id], onDelete: SetNull)
  emailLogs EmailLog[]

  @@index([fulfillmentStatus, createdAt]) // 처리 대기 주문 조회
  @@index([naverOrderId])                 // 주문번호로 묶음 조회
  @@map("steam_order_items")
}

// 이메일 발송 이력 (재시도 포함 모든 발송 시도 기록)
model EmailLog {
  id             String         @id @default(uuid()) @db.Uuid
  orderItemId    String         @map("order_item_id") @db.Uuid
  recipientEmail String         @map("recipient_email") @db.VarChar(320) // 실제 발송한 이메일 주소
  status         EmailLogStatus @default(queued)
  errorMessage   String?        @map("error_message")                    // 발송 실패 사유
  sentAt         DateTime?      @map("sent_at") @db.Timestamptz(6)      // 실제 발송 완료 시각
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  orderItem SteamOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, createdAt])
  @@map("email_logs")
}
