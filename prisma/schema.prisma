generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  draft
  active
  inactive
}

enum AccountStatus {
  available
  reserved
  sent
  disabled
  manual
}

enum FulfillmentStatus {
  pending
  completed
  manual_review
  failed
  returned
}

enum DeliveryChannel {
  alimtalk
}

enum DeliveryLogStatus {
  queued
  sent
  failed
}

enum ReviewCodeStatus {
  unused
  used
}

enum ExpenseCategory {
  game_purchase
  country_change
  review_game
  other
}

enum ExpensePayer {
  song_donggeon
  im_jeongbin
}

model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(320)
  password  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admins")
}

model SteamProduct {
  id             String           @id @default(uuid()) @db.Uuid
  name           String           @db.VarChar(255)
  naverProductId String           @unique @map("naver_product_id") @db.VarChar(100)
  price          Int?             @map("price")
  status         ProductStatus    @default(draft)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts       SteamAccount[]
  orderItems     SteamOrderItem[]

  @@map("steam_products")
}

model SteamAccount {
  id            String        @id @default(uuid()) @db.Uuid
  productId            String?       @map("product_id") @db.Uuid
  productNameSnapshot  String?       @map("product_name_snapshot") @db.VarChar(255)
  username      String
  password      String
  email         String        @map("email") @db.VarChar(320)
  emailPassword String        @map("email_password")
  emailSiteUrl  String        @map("email_site_url") @db.VarChar(2048)
  secondaryEmail         String?  @map("secondary_email") @db.VarChar(320)
  secondaryEmailPassword String?  @map("secondary_email_password")
  secondaryEmailSiteUrl  String?  @map("secondary_email_site_url") @db.VarChar(2048)
  status        AccountStatus @default(available)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  product       SteamProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  orderItems    SteamOrderItem[]

  @@index([productId, status, createdAt])
  @@map("steam_accounts")
}

model SteamOrderItem {
  id                  String            @id @default(uuid()) @db.Uuid
  productOrderId      String            @unique @map("product_order_id") @db.VarChar(100)
  naverOrderId        String            @map("naver_order_id") @db.VarChar(100)
  productId           String?           @map("product_id") @db.Uuid
  accountId           String?           @map("account_id") @db.Uuid
  productName         String            @map("product_name") @db.VarChar(255)
  receiverPhoneNumber String?           @map("receiver_phone_number") @db.VarChar(30)
  receiverName        String?           @map("receiver_name") @db.VarChar(100)
  unitPrice           Int               @map("unit_price")
  settlementAmount    Int?              @map("settlement_amount")
  decisionDate        DateTime?         @map("decision_date") @db.Timestamptz(6)
  fulfillmentStatus   FulfillmentStatus @default(pending) @map("fulfillment_status")
  errorMessage        String?           @map("error_message")
  paidAt              DateTime?         @map("paid_at") @db.Timestamptz(6)
  returnedAt          DateTime?         @map("returned_at") @db.Timestamptz(6)
  reviewGameSentAt    DateTime?         @map("review_game_sent_at") @db.Timestamptz(6)
  friendLink1         String?           @map("friend_link1") @db.VarChar(500)
  friendLink2         String?           @map("friend_link2") @db.VarChar(500)
  giftCompletedAt     DateTime?         @map("gift_completed_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  product             SteamProduct?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  account             SteamAccount?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  deliveryLogs        DeliveryLog[]

  @@index([fulfillmentStatus, createdAt])
  @@index([naverOrderId])
  @@map("steam_order_items")
}

model DeliveryLog {
  id                String            @id @default(uuid()) @db.Uuid
  orderItemId       String            @map("order_item_id") @db.Uuid
  channel           DeliveryChannel   @map("channel")
  recipient         String            @map("recipient") @db.VarChar(100)
  templateCode      String?           @map("template_code") @db.VarChar(50)
  status            DeliveryLogStatus @default(queued)
  errorMessage      String?           @map("error_message")
  providerMessageId String?           @map("provider_message_id") @db.VarChar(100)
  sentAt            DateTime?         @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  orderItem         SteamOrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, createdAt])
  @@map("delivery_logs")
}

model AlimtalkSettings {
  id              String   @id @default(uuid()) @db.Uuid
  enabled         Boolean  @default(true)
  messageTemplate String   @map("message_template")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("alimtalk_settings")
}

model ReviewCode {
  id        String           @id @default(uuid()) @db.Uuid
  gameName  String?          @map("game_name") @db.VarChar(255)
  code      String           @db.VarChar(255)
  status    ReviewCodeStatus @default(unused)
  usedBy    String?          @map("used_by") @db.VarChar(255)
  usedAt    DateTime?        @map("used_at") @db.Timestamptz(6)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([gameName])
  @@map("review_codes")
}

model SystemSettings {
  id               String   @id @default(uuid()) @db.Uuid
  alimtalkUnitCost Decimal  @default(6.5) @map("alimtalk_unit_cost") @db.Decimal(7, 1)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model ManualRevenue {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date
  amount    Int
  memo      String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([date])
  @@map("manual_revenues")
}

model Expense {
  id        String          @id @default(uuid()) @db.Uuid
  date      DateTime        @db.Timestamptz(6)
  category  ExpenseCategory
  payer     ExpensePayer    @default(song_donggeon)
  amount    Int
  memo      String?         @db.VarChar(500)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([date])
  @@index([category, date])
  @@map("expenses")
}

// ───────────────────────── 유저 인증 (OTTALL) ─────────────────────────

enum AuthProvider {
  local
  kakao
  google
}

model User {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique @db.VarChar(320)
  password      String?
  name          String       @db.VarChar(100)
  phone         String       @unique @db.VarChar(20)
  phoneVerified Boolean      @default(false) @map("phone_verified")
  provider      AuthProvider @default(local)
  providerId    String?      @map("provider_id") @db.VarChar(255)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  ownProducts        OwnProduct[]
  partner            Partner?
  termsAgreements    TermsAgreement[]
  partyApplications  PartyApplication[]

  @@unique([provider, providerId])
  @@map("users")
}

model TermsAgreement {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  type     String   @db.VarChar(30)
  agreedAt DateTime @default(now()) @map("agreed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("terms_agreements")
}

// ───────────────────────── OTT 상품 (OTTALL) ─────────────────────────

enum OwnProductStatus {
  recruiting
  closed
  expired
}

enum PartnerStatus {
  pending
  approved
  rejected
}

enum PartyApplicationStatus {
  pending
  confirmed
  cancelled
  expired
}

enum PaymentStatus {
  pending
  paid
  cancelled
}

enum PaymentMethod {
  manual
  pg
}

model OwnCategory {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @unique @db.VarChar(100)
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  products  OwnProduct[]

  @@map("own_categories")
}

model OwnProduct {
  id           String           @id @default(uuid()) @db.Uuid
  name         String           @db.VarChar(255)
  categoryId   String           @map("category_id") @db.Uuid
  durationDays Int              @map("duration_days")
  price         Int
  dailyDiscount Int              @default(0) @map("daily_discount")
  totalSlots    Int              @map("total_slots")
  filledSlots  Int              @default(0) @map("filled_slots")
  imagePath    String?          @map("image_path") @db.VarChar(500)
  notes           String?          @db.Text
  accountId       String?          @map("account_id") @db.Text
  accountPassword String?          @map("account_password") @db.Text
  status          OwnProductStatus @default(recruiting)
  startedAt    DateTime?        @map("started_at") @db.Timestamptz(6)
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz(6)
  userId       String           @map("user_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  category     OwnCategory        @relation(fields: [categoryId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  applications PartyApplication[]

  @@index([categoryId, status])
  @@index([userId])
  @@index([status, createdAt])
  @@map("own_products")
}

model PartyApplication {
  id          String                 @id @default(uuid()) @db.Uuid
  productId   String                 @map("product_id") @db.Uuid
  userId      String                 @map("user_id") @db.Uuid
  price       Int
  fee         Int
  totalAmount Int                    @map("total_amount")
  status      PartyApplicationStatus @default(pending)
  startedAt   DateTime?              @map("started_at") @db.Timestamptz(6)
  expiresAt   DateTime?              @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  product  OwnProduct @relation(fields: [productId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  payments Payment[]

  @@unique([productId, userId])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@map("party_applications")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  applicationId   String        @map("application_id") @db.Uuid
  amount          Int
  method          PaymentMethod @default(manual)
  status          PaymentStatus @default(pending)
  payMethod       String?       @map("pay_method") @db.VarChar(30)
  pgTransactionId String?       @map("pg_transaction_id") @db.VarChar(255)
  pgProvider      String?       @map("pg_provider") @db.VarChar(50)
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz(6)
  adminNote       String?       @map("admin_note") @db.VarChar(500)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  application PartyApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([status, createdAt])
  @@map("payments")
}

model PhoneVerification {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone, createdAt])
  @@map("phone_verifications")
}

// ───────────────────────── 파트너 (OTTALL) ─────────────────────────

model Partner {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @unique @map("user_id") @db.Uuid
  name          String        @db.VarChar(100)
  phone         String        @db.VarChar(20)
  bankName      String        @map("bank_name") @db.VarChar(50)
  bankAccount   String        @map("bank_account") @db.VarChar(50)
  status        PartnerStatus @default(pending)
  rejectedAt    DateTime?     @map("rejected_at") @db.Timestamptz(6)
  rejectionNote String?       @map("rejection_note") @db.VarChar(500)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("partners")
}
